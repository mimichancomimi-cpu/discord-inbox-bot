# このファイルをコピーして .env にリネームし、値を設定してください。
# .env は Git にコミットしないでください。

DISCORD_BOT_TOKEN=Discord開発者ポータルで発行したBotトークン
DISCORD_GUILD_ID=つきのわハウスのサーバーID（数値）

# 保存先（Vault ルートからの相対パス）
DISCORD_ARCHIVE_OUTPUT_DIR=brain/つきのわハウス/Discordログ

# 差分取得の状態ファイル
DISCORD_ARCHIVE_STATE_PATH=brain/scripts/discord_obsidian_archiver/state.json

# 1: スレッドも取得する, 0: スレッドは取得しない
DISCORD_ARCHIVE_INCLUDE_THREADS=1

# 常駐実行時の同期間隔（秒）
DISCORD_ARCHIVE_INTERVAL_SEC=300
