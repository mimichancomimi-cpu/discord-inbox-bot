# このファイルをコピーして  にリネームし、値を埋める。 は Git に載せない。

DISCORD_BOT_TOKEN=Discord開発者ポータルで発行したBotトークン
DISCORD_CHANNEL_ID=メッセージを受け取りたいテキストチャンネルのID（数値）

GITHUB_TOKEN=github_pat_xxx（repo 権限のFine-grainedまたはclassic）
GITHUB_REPO=あなたのユーザー名/リポジトリ名

# リポジトリ内のパス（デフォルトはこのVault想定）
GITHUB_FILE_PATH=brain/タスク管理/Discord自動受信箱.md

# 最後に処理した Discord メッセージIDの保存先（省略可）
STATE_FILE=.state.json
# ローカル追記先（brain からの相対パス or 絶対パス）
LOCAL_FILE_PATH=タスク管理/Discord自動受信箱.md
# 自動タスク管理ファイル（brain からの相対パス or 絶対パス）
TASK_FILE_PATH=タスク管理/自動タスク一覧.md

# 予定自動追加（1: 有効, 0: 無効）
ENABLE_CALENDAR_AUTO_ADD=1
# この接頭辞で始まる投稿のみカレンダー登録する（誤爆防止）
CALENDAR_COMMAND_PREFIX=予定:
# カレンダー登録時のタイムゾーン
CALENDAR_TIMEZONE=Asia/Tokyo
# かんたん入力（終了時刻なし）のデフォルト所要時間（分）
CALENDAR_DEFAULT_DURATION_MIN=60

# 毎朝サマリー投稿設定
# SUMMARY_CHANNEL_ID=123456789012345678  # 省略時は DISCORD_CHANNEL_ID を使用
SUMMARY_POST_HOUR_JST=8
SUMMARY_POST_MINUTE_JST=0
# 随時サマリー用の追加キーワード（カンマ区切り。省略時は bot.py のデフォルト＋サマリーテスト互換）
# SUMMARY_NOW_KEYWORDS=今のタスク,確認したい
